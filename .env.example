# ============================================================
# MIA - Variables de entorno (copia este archivo a .env y complétalo)
# ============================================================
# NO subas .env al repositorio (está en .gitignore).

# --- Groq (STT Whisper + LLM Llama). Gratis en https://console.groq.com ---
GROQ_API_KEY=

# --- Voz (TTS) ---
# Motor de voz: "elevenlabs" (natural, con emoción) o "edge" (gratis, sin cuenta).
TTS_ENGINE=elevenlabs
# ElevenLabs: crea cuenta gratis en https://elevenlabs.io (acepta gmail, sin tarjeta)
# y pega tu API key (Perfil -> API Keys). Capa gratis ~10 min de audio al mes.
ELEVENLABS_API_KEY=
# (Opcional) ID de otra voz de tu Voice Library. Por defecto usa "Rachel".
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# (Opcional) eleven_multilingual_v2 (calidad) o eleven_turbo_v2_5 (rápido, +créditos).
# ELEVENLABS_MODEL=eleven_multilingual_v2
# (Opcional) Voz de edge-tts si usas TTS_ENGINE=edge.
# TTS_VOICE=es-MX-DaliaNeural

# --- Picovoice / Porcupine (wake word). Gratis en https://console.picovoice.ai ---
PICOVOICE_ACCESS_KEY=
# Ruta al modelo .ppn de la palabra "Mia" entrenado en Picovoice Console.
# Usa el .ppn de plataforma "Raspberry Pi" en la Pi, o "Windows" en dev.
PICOVOICE_KEYWORD_PATH=./mia.ppn
# Sensibilidad del wake word (0.0 - 1.0). Más alto = más sensible.
PICOVOICE_SENSITIVITY=0.5

# --- Opcionales ---
# Forzar modo simulado de GPIO (1/true) para probar en una PC sin hardware.
# Si se omite, se auto-detecta (mock si no hay backend GPIO real).
# USE_MOCK_GPIO=

# Activar el panel web con avatar (pesado en la Pi 3). Por defecto: false.
# ENABLE_WEB_PANEL=false

# --- Música de espera (suena mientras se dispensa la bebida) ---
# Activar/desactivar la música de espera. Por defecto: true.
# MUSIC_ENABLED=true
# Volumen inicial de la música (0.0 - 1.0). En el panel web se ajusta en vivo.
# MUSIC_VOLUME=0.4
# Volumen inicial de la voz de MIA en el navegador (0.0 - 1.0).
# VOICE_VOLUME=1.0
