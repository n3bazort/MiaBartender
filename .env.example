# ============================================================
# MIA - Variables de entorno (copia este archivo a .env y complétalo)
# ============================================================
# NO subas .env al repositorio (está en .gitignore).

# --- Groq (STT Whisper + LLM Llama). Gratis en https://console.groq.com ---
GROQ_API_KEY=

# --- Voz (TTS) ---
# Motor de voz: "elevenlabs" (natural, con emoción) o "edge" (gratis, sin cuenta).
TTS_ENGINE=elevenlabs
# ElevenLabs: crea cuenta gratis en https://elevenlabs.io (acepta gmail, sin tarjeta)
# y pega tu API key (Perfil -> API Keys). Capa gratis ~10 min de audio al mes.
ELEVENLABS_API_KEY=
# (Opcional) ID de otra voz de tu Voice Library. Por defecto usa "Rachel".
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# (Opcional) eleven_multilingual_v2 (calidad) o eleven_turbo_v2_5 (rápido, +créditos).
# ELEVENLABS_MODEL=eleven_multilingual_v2
# (Opcional) Voz de edge-tts si usas TTS_ENGINE=edge.
# TTS_VOICE=es-MX-DaliaNeural

# --- Palabra de activación (por defecto "Mia") ---
# NO necesita cuenta, clave ni registro: usa Vosk, un motor de voz offline
# libre. El modelo se baja una vez con:  python descargar_modelo.py
#
# >>> PARA CAMBIARLE EL NOMBRE, descomenta esta línea y pon el que quieras.
#     Es lo ÚNICO que hay que tocar: los mensajes de la pantalla y de la
#     consola se actualizan solos. Reinicia MIA después del cambio.
# WAKE_KEYWORD=mia
#
# Funciona mejor con nombres de 2-3 sílabas que existan en español
# (Mia, Sofía, Carla, Elena...). Un invento raro puede no reconocerlo bien.
# Los ACENTOS no hay que ponerlos: la comparación ya los ignora.
#
# (Opcional) Pronunciaciones alternativas, separadas por comas. Solo hace
# falta si el nombre se puede decir de formas muy distintas. Por defecto
# se usa el valor de WAKE_KEYWORD.
# VOSK_WAKE_VARIANTS=mia,mia mia
#
# Motor: "auto" (por defecto), "vosk" o "porcupine".
# WAKE_ENGINE=auto

# --- Picovoice (OPCIONAL: alternativa que gasta menos CPU) ---
# Solo si tienes cuenta en https://console.picovoice.ai (pide correo de
# empresa). Si dejas esto vacío, MIA usa Vosk y funciona igual.
# PICOVOICE_ACCESS_KEY=
# PICOVOICE_KEYWORD_PATH=
# PICOVOICE_SENSITIVITY=0.5

# --- Audio de la Raspberry Pi (micro USB + parlantes USB) ---
# Entrada de voz: "local" = micro USB + wake word (Pi). "web" = micrófono del
# navegador (pruebas desde la laptop; equivale a  python main.py --web).
# MIA_INPUT=local
# Índice del micrófono. Sin definir = auto-detecta (prefiere USB).
# Míralos con:  python listar_audio.py
# MIC_DEVICE_INDEX=
# Salida de ALSA para los parlantes USB (mpg123 -a). Ej: hw:1,0
# Si se escucha por el jack en vez de los parlantes USB, fíjalo aquí.
# AUDIO_OUTPUT_DEVICE=

# --- Opcionales ---
# Forzar modo simulado de GPIO (1/true) para probar en una PC sin hardware.
# Si se omite, se auto-detecta (mock si no hay backend GPIO real).
# USE_MOCK_GPIO=

# Activar el panel web con avatar (pesado en la Pi 3). Por defecto: false.
# ENABLE_WEB_PANEL=false

# --- Música de espera (suena mientras se dispensa la bebida) ---
# Activar/desactivar la música de espera. Por defecto: true.
# MUSIC_ENABLED=true
# Volumen inicial de la música (0.0 - 1.0). En el panel web se ajusta en vivo.
# MUSIC_VOLUME=0.4
# Volumen inicial de la voz de MIA en el navegador (0.0 - 1.0).
# VOICE_VOLUME=1.0
